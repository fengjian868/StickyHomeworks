<Window x:Class="StickyHomeworks.Views.KeyboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StickyHomeworks.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="{x:Null}"
        SizeToContent="Height"
        Title="键盘"
        Opacity="0.8">
    <Window.Resources>
        <Storyboard x:Key="SlideUpStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="(Window.Top)"
                             Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>
    <controls:HomeworkKeyboard x:Name="KeyboardControl" Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Width}"/>
</Window>
