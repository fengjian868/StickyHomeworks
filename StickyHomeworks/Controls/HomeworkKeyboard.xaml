<UserControl x:Class="StickyHomeworks.Controls.HomeworkKeyboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:StickyHomeworks.Controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             d:DesignHeight="400" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Win11 风格按键 -->
        <Style x:Key="Win11KeyStyle" TargetType="Button">
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="2 3"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
            <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource MaterialDesignToolBarBackground}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource MaterialDesignSelection}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 功能键样式 -->
        <Style x:Key="Win11ActionKeyStyle" TargetType="Button" BasedOn="{StaticResource Win11KeyStyle}">
            <Setter Property="Background" Value="{DynamicResource MaterialDesignToolBarBackground}"/>
            <Setter Property="MinWidth" Value="44"/>
        </Style>
        <!-- 完成按钮样式 -->
        <Style x:Key="Win11DoneKeyStyle" TargetType="Button" BasedOn="{StaticResource Win11KeyStyle}">
            <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <!-- 分类标签 -->
        <Style x:Key="CategoryLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="4 2"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource MaterialDesignPaper}"
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="1"
            CornerRadius="8"
            Effect="{DynamicResource MaterialDesignShadowDepth2}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 拖动手柄 -->
                <RowDefinition Height="Auto"/>
                <!-- 数字 -->
                <RowDefinition Height="Auto"/>
                <!-- 中文数字 -->
                <RowDefinition Height="Auto"/>
                <!-- 书本 -->
                <RowDefinition Height="Auto"/>
                <!-- 时间1 -->
                <RowDefinition Height="Auto"/>
                <!-- 时间2 -->
                <RowDefinition Height="Auto"/>
                <!-- 内容 -->
                <RowDefinition Height="Auto"/>
                <!-- 符号 -->
                <RowDefinition Height="Auto"/>
                <!-- 字母 -->
                <RowDefinition Height="Auto"/>
                <!-- 其他 -->
                <RowDefinition Height="Auto"/>
                <!-- 操作 -->
                <RowDefinition Height="Auto"/>
                <!-- 完成 -->
            </Grid.RowDefinitions>

            <!-- 拖动手柄 -->
            <Grid Grid.Row="0" Height="20" Cursor="SizeAll" MouseLeftButtonDown="DragHandle_OnMouseLeftButtonDown">
                <Border Width="40" Height="4" CornerRadius="2"
                        Background="{DynamicResource MaterialDesignBodyLight}"
                        VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Grid>

            <!-- 数字行 -->
            <Grid Grid.Row="1" Margin="4 2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="数字" Style="{StaticResource CategoryLabelStyle}"/>
                <UniformGrid Grid.Column="1" x:Name="NumberPanel" Columns="11"/>
            </Grid>

            <!-- 中文数字行 -->
            <Grid Grid.Row="2" Margin="4 2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="数字" Style="{StaticResource CategoryLabelStyle}"/>
                <UniformGrid Grid.Column="1" x:Name="ChineseNumberPanel" Columns="11"/>
            </Grid>

            <!-- 书本行 -->
            <Grid Grid.Row="3" Margin="4 2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="书本" Style="{StaticResource CategoryLabelStyle}"/>
                <UniformGrid Grid.Column="1" x:Name="BookPanel" Columns="9"/>
            </Grid>

            <!-- 时间行1 -->
            <Grid Grid.Row="4" Margin="4 2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="时间" Style="{StaticResource CategoryLabelStyle}"/>
                <UniformGrid Grid.Column="1" x:Name="TimePanel1" Columns="10"/>
            </Grid>

            <!-- 时间行2 -->
            <Grid Grid.Row="5" Margin="4 2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="时间" Style="{StaticResource CategoryLabelStyle}"/>
                <UniformGrid Grid.Column="1" x:Name="TimePanel2" Columns="10"/>
            </Grid>

            <!-- 内容行 -->
            <Grid Grid.Row="6" Margin="4 2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="内容" Style="{StaticResource CategoryLabelStyle}"/>
                <UniformGrid Grid.Column="1" x:Name="ContentPanel" Columns="10"/>
            </Grid>

            <!-- 符号行 -->
            <Grid Grid.Row="7" Margin="4 2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="符号" Style="{StaticResource CategoryLabelStyle}"/>
                <UniformGrid Grid.Column="1" x:Name="SymbolPanel" Columns="10"/>
            </Grid>

            <!-- 常用字母行 -->
            <Grid Grid.Row="8" Margin="4 2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="字母" Style="{StaticResource CategoryLabelStyle}"/>
                <UniformGrid Grid.Column="1" x:Name="LetterPanel" Columns="5"/>
            </Grid>

            <!-- 其他行 -->
            <Grid Grid.Row="9" Margin="4 2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="其他" Style="{StaticResource CategoryLabelStyle}"/>
                <UniformGrid Grid.Column="1" x:Name="CustomPanel" Columns="10"/>
            </Grid>

            <!-- 功能键行 -->
            <Grid Grid.Row="10" Margin="4 6 4 4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="操作" Style="{StaticResource CategoryLabelStyle}"/>
                <UniformGrid Grid.Column="1" Columns="3">
                    <Button Content="删除" Style="{StaticResource Win11ActionKeyStyle}"
                            ToolTip="删除" Click="ButtonBackspace_OnClick"/>
                    <Button Content="换行" Style="{StaticResource Win11ActionKeyStyle}"
                            ToolTip="换行" Click="ButtonEnter_OnClick"/>
                    <Button Content="关闭" Style="{StaticResource Win11ActionKeyStyle}"
                            ToolTip="关闭" Click="ButtonClose_OnClick"/>
                </UniformGrid>
            </Grid>

            <!-- 完成按钮行 -->
            <Grid Grid.Row="11" Margin="4 2 4 6">
                <Button Content="完成" Style="{StaticResource Win11DoneKeyStyle}"
                        HorizontalAlignment="Stretch"
                        Click="ButtonDone_OnClick"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
